# Kotak Neo API Credentials
# Obtain from https://napi.kotaksecurities.com/devportal
NEO_CONSUMER_KEY=your_consumer_key_here
NEO_CONSUMER_SECRET=your_consumer_secret_here
NEO_ACCESS_TOKEN=your_access_token_here
NEO_UCC=your_5char_ucc_here
NEO_ENVIRONMENT=prod

# Interactive auth (prompted at startup if not set in env)
NEO_MOBILE=+91XXXXXXXXXX
NEO_MPIN=your_6digit_mpin

# Trading Configuration
LIVE_TRADE=false          # Set to true to enable live order placement
DRY_RUN_LOG=true          # Log simulated trades when LIVE_TRADE=false
